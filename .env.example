# Database (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
# Generate with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Set to true to skip email verification (development only — never use in production)
# SKIP_EMAIL_VERIFICATION=true

# Cloudflare R2 (https://dash.cloudflare.com → R2 → Manage API Tokens)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""             # Public bucket URL (server-side)
NEXT_PUBLIC_R2_PUBLIC_URL="" # Same value — exposed to the browser for image previews

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
